# pixi-managed conda environment (pixi.lock IS tracked)
/.pixi/

# Repo-local build output (Spack install tree, caches, env view, logs, etc.)
/working_dir/

# Spack directory-environment state, one set per variant. The variant manifests
# (spack-env/<variant>/spack.yaml), the shared spack-env/common.yaml, AND the
# resolved lock (spack-env/<variant>/spack.lock) are all tracked: the lock is the
# Spack analogue of pixi.lock, so `build` installs the exact same specs on a fresh
# checkout (refresh it deliberately with `pixi run concretize`). Only the
# per-build view + internal caches under .spack-env/ are transient, so only that
# is ignored.
/spack-env/*/.spack-env/

# Logs / batch output
*.log
*.out
*.err
/.submodule-add.log

# OS process core dumps (`core`, `core.<pid>`). The kernel writes these to a
# crashing process's working directory on SIGSEGV/SIGABRT — they are NOT a build
# artifact or the lfric_atm binary (the one seen at the repo root was a multi-GB
# dump from the VS Code server's `node` process). Anchored to the repo root;
# safe to delete to reclaim space.
/core
/core.*

# Python / OS cruft
__pycache__/
*.pyc
*~
*.swp
*.swo
.DS_Store
