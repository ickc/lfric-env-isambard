# pixi-managed conda environment (pixi.lock IS tracked)
/.pixi/

# All build output lands OUTSIDE the repo under PREFIX (LFRIC_PREFIX; default
# $PROJECTDIR/$USER/opt/<arch>, see scripts/common.sh) and the transient stage
# under WORKING_DIR (LFRIC_WORKING_DIR; default $PREFIX/stage) — so nothing build-
# related is tracked. The rules below are a safety net only, in case an older
# build (or a repo-relative LFRIC_PREFIX) ever wrote state into the repo.
/working_dir/
/stage/
/spack-env/*/.spack-env/
/spack-env/*/spack.lock

# sbatch stdout (#SBATCH --output=logs/...). The dir is tracked via .gitkeep so a
# fresh clone has it; the *.out/*.log files in it are ignored by the rules below.
/logs/*
!/logs/.gitkeep

# Logs / batch output
*.log
*.out
*.err
/.submodule-add.log

# OS process core dumps (`core`, `core.<pid>`). The kernel writes these to a
# crashing process's working directory on SIGSEGV/SIGABRT — they are NOT a build
# artifact or the lfric_atm binary (the one seen at the repo root was a multi-GB
# dump from the VS Code server's `node` process). Anchored to the repo root;
# safe to delete to reclaim space.
/core
/core.*

# Python / OS cruft
__pycache__/
*.pyc
*~
*.swp
*.swo
.DS_Store

# Science-suite examples (examples/science-suites/) generated state, written by `cylc install`.
examples/science-suites/*/opt/rose-suite-cylc-install.conf
