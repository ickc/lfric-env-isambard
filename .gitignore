# pixi-managed conda environment (pixi.lock IS tracked)
/.pixi/

# Repo-local build output (Spack install tree, caches, env view, logs, etc.)
/working_dir/

# Spack directory-environment runtime state (view + generated lockfile).
# The environment definition spack-env/spack.yaml IS tracked; spack.lock is
# regenerated by `build` (concretize -f), so it is not.
/spack-env/.spack-env/
/spack-env/spack.lock

# Logs / batch output
*.log
*.out
*.err
/.submodule-add.log

# Python / OS cruft
__pycache__/
*.pyc
*~
*.swp
*.swo
.DS_Store
