# pixi-managed conda environment (pixi.lock IS tracked)
/.pixi/

# Legacy repo-local build output. Build output now defaults OUTSIDE the repo
# under PREFIX ($PROJECTDIR/$USER/opt/<arch> by default; see scripts/common.sh),
# but keep this ignore for older trees / an explicit LFRIC_WORKING_DIR=working_dir.
/working_dir/

# Spack directory-environment state. The whole environment (manifest + view +
# lockfile) is now GENERATED under PREFIX by `build`; the tracked spack-env/
# <variant>/spack.yaml are TEMPLATES. These ignores remain as a safety net in
# case a stale .spack-env/ was ever created in-repo by an older build.
/spack-env/*/.spack-env/
/spack-env/*/spack.lock

# sbatch stdout (#SBATCH --output=logs/...). The dir is tracked via .gitkeep so a
# fresh clone has it; the *.out/*.log files in it are ignored by the rules below.
/logs/*
!/logs/.gitkeep

# Logs / batch output
*.log
*.out
*.err
/.submodule-add.log

# OS process core dumps (`core`, `core.<pid>`). The kernel writes these to a
# crashing process's working directory on SIGSEGV/SIGABRT — they are NOT a build
# artifact or the lfric_atm binary (the one seen at the repo root was a multi-GB
# dump from the VS Code server's `node` process). Anchored to the repo root;
# safe to delete to reclaim space.
/core
/core.*

# Python / OS cruft
__pycache__/
*.pyc
*~
*.swp
*.swo
.DS_Store
